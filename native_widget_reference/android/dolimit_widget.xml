<?xml version="1.0" encoding="utf-8"?>
<!-- 配置先: android/app/src/main/res/layout/dolimit_widget.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TODAY 残り"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#8A8A8E" />

    <TextView
        android:id="@+id/widget_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#111114" />

    <TextView
        android:id="@+id/widget_titles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="3"
        android:ellipsize="end"
        android:text="TODAYは空です"
        android:textSize="12sp"
        android:textColor="#3A3A3C" />
</LinearLayout>
